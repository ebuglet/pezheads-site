          <td width="18%" valign="top"><font size="2" face="Verdana, Arial"><b>Alex</b></font></td>
          <td>
            <font size="2" face="Verdana, Arial"><font size="1" color="#000080" face="Verdana, Arial">posted 11-06-98 11:00 PM CT (US)</font></font>
