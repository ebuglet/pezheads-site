<!DOCTYPE html>
<html>
<head>
  <title>Flip Me Some PEZ Forums Search Page</title>
</head>
<body bgcolor="#FFFFFF" text="#000000" link="#000080" vlink="#2F2F4F">
  <form action="search.cgi" method="post">
    <table border="0" width="95%">
      <tr>
        <td></td>
        <td valign="bottom">
          <center>
            <font face="Verdana, Arial" size="1"><a href="index.cgi?action=intro&BypassCookie=true">Back to Bulletin Board</a> | <a href="/cgi-bin/forum/index.cgi?action=agree"><acronym title="Registration is free!">register</acronym></a> | <a href="/cgi-bin/forum/ubbmisc.cgi?action=editbio"><acronym title="Click here to edit your profile.">profile</acronym></a> | <a href="/cgi-bin/forum/ubbmisc.cgi?action=setprefs"><acronym title="Set your preferences.">prefs</acronym></a></font>
          </center>
        </td>
      </tr>
      <tr bgcolor="#F7F7F7">
        <td align="right" valign="top"><font size="2" face="Verdana, Arial"><b>Search Words:</b></font></td>
        <td>
          <input type="text" name="SearchTerms" size="20" maxlength="25"><br>
          <font size="1" face="Verdana, Arial" color="#000080"><input type="radio" name="BooleanAND" value="YES" checked> Match all search terms above.<br>
          <input type="radio" name="BooleanAND" value="NO"> Match any of the search terms above.</font>
          <p><font size="1" face="Verdana, Arial" color="#000080">Separate words with spaces, not commas.</font></p>
        </td>
      </tr>
      <tr bgcolor="#DEDFDF">
        <td valign="top" align="right"><font size="2" face="Verdana, Arial"><b>Search Forum:</b></font></td>
        <td><font size="2" face="Verdana, Arial"><select name="ForumChoice">
          <option value="ALL">
            All Forums
          </option>
          <option value="4">
            Collecting Questions
          </option>
          <option value="1">
            Dispensers For Sale
          </option>
          <option value="2">
            Dispensers Wanted
          </option>
          <option value="3">
            News/Announcements
          </option>
          <option value="5">
            Website Suggestions/Comments
          </option>
        </select></font></td>
      </tr>
      <tr bgcolor="#F7F7F7">
        <td align="right"><font size="2" face="Verdana, Arial"><b>Search In:</b></font></td>
        <td><select name="SearchIn">
          <option value="ALL">
            Entire Message
          </option>
          <option value="SUBJECT">
            Subject Only
          </option>
        </select></td>
      </tr>
      <tr bgcolor="#DEDFDF">
        <td align="right"><font size="2" face="Verdana, Arial"><b>Search By Date:</b></font></td>
        <td><select name="SearchDate">
          <option value="ALL">
            Any Date
          </option>
          <option value="1">
            Since Yesterday
          </option>
          <option value="5">
            Since 5 Days Ago
          </option>
          <option value="10">
            Since 10 Days Ago
          </option>
          <option value="30">
            Since 30 Days Ago
          </option>
        </select></td>
      </tr>
      <tr bgcolor="#F7F7F7">
        <td align="right" valign="top"><font size="2" face="Verdana, Arial"><b>Search by User Name:</b></font></td>
        <td valign="top"><font face="Verdana, Arial" color="#000080" size="1"><input type="text" name="SearchUser" size="20" maxlength="25"><br>
        <input type="radio" name="ExactName" value="yes">Search For Exact Name (case sensitive)<br>
        <input type="radio" name="ExactName" value="no" checked>Partial Name Match Acceptable</font></td>
      </tr>
    </table><input type="hidden" name="action" value="simplesearch">
    <center>
      <input type="submit" name="Submit" value="Perform Search"> <input type="reset" name="Reset" value="Reset Fields">
    </center>
  </form>
  <p><font size="2" face="Verdana, Arial"></font></p>
  <p><font color="#FEFEFE" size="1" face="Verdana, Arial">All posts are the property of the <i>Flip Me Some PEZ</i> website and may not be used for any reason.</font></p>
  <p><font color="#FEFEFE" size="1" face="Verdana, Arial">Powered by: Ultimate Bulletin Board<br>
  &copy; Madrona Park, Inc., 1998.<br>
  <br></font></p>
</body>
</html>
